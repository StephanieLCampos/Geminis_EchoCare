rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Voice samples: only the caregiver who owns them
    match /voice-samples/{userId}.mp3 {
      allow read, write: if request.auth.uid == userId;
    }

    // Elderly profile photos: authenticated users
    match /elderly-profiles/{file} {
      allow read, write: if request.auth != null;
    }

    // Reminder media (audio/video): authenticated users
    match /audio/{file} {
      allow read, write: if request.auth != null;
    }
    match /videos/{file} {
      allow read, write: if request.auth != null;
    }
  }
}
