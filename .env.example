# Copy to .env and fill in values
# Expo loads .env automatically - EXPO_PUBLIC_* vars are available in the app

# Voice API (ElevenLabs backend) - REQUIRED for voice reminders
# - Web / Simulator: http://localhost:3001 works
# - Physical device (Expo Go): Use your computer's LAN IP so the phone can reach it
#   Find your IP: Mac: System Settings > Network | or run: ipconfig getifaddr en0
EXPO_PUBLIC_VOICE_API_URL=http://172.31.220.26:3001
